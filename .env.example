# Admin Go server
ADMIN_HTTP_ADDR=:3001
BACKEND_GRPC_ADDR=localhost:50051

# Shared admin key for backend gRPC metadata
# (backend expects ADMIN_SECRET_KEY or SECRET_KEY)
ADMIN_SECRET_KEY=

# Authentik OIDC (optional; when set, admin UI + /api/* require login)
# In dev (Vite), set APP_URL to the Vite origin (e.g. http://localhost:5173)
# In prod, set APP_URL to the public admin URL (e.g. https://admin.example.com)
APP_URL=http://localhost:5173
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_URL=https://auth.example.com
AUTHENTIK_PROVIDER=

# Used to sign/encrypt the admin session cookie
JWT_SECRET=
